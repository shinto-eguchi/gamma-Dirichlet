    "# ============================================================\n",
    "# Gamma-Dirichlet and diffusion-map clustering\n",
    "# ============================================================\n",
    "\n",
    "def gamma_dirichlet_clustering(\n",
    "    K: csr_matrix,\n",
    "    gamma: float,\n",
    "    n_clusters: int = 2,\n",
    "    seed: int = 0,\n",
    ") -> Tuple[np.ndarray, np.ndarray, float]:\n",
    "    \"\"\"Gamma-Dirichlet clustering on the escort-conductance graph.\n",
    "\n",
    "    The node mass is the normalized kernel degree q_i.  The conductance is\n",
    "\n",
    "        c_ij = (q_i q_j)^gamma K_ij.\n",
    "\n",
    "    Positive gamma suppresses low-degree scatter clutter by reducing its\n",
    "    endpoint conductance before the Laplacian is formed.\n",
    "    \"\"\"\n",
    "\n",
    "    degree = np.asarray(K.sum(axis=1)).ravel()\n",
    "    q = (degree + EPS) / np.sum(degree + EPS)\n",
    "\n",
    "    Q_gamma = diags(q ** gamma)\n",
    "    C_gamma = Q_gamma @ K @ Q_gamma\n",
    "\n",
    "    return normalized_spectral_clustering(\n",
    "        C_gamma,\n",
    "        n_clusters=n_clusters,\n",
    "        seed=seed,\n",
    "    )\n",
    "\n",
    "\n",
    "def diffusion_map_clustering(\n",
    "    K: csr_matrix,\n",
    "    alpha: float,\n",
    "    n_clusters: int = 2,\n",
    "    diffusion_time: float = 1.0,\n",
    "    seed: int = 0,\n",
    ") -> Tuple[np.ndarray, np.ndarray, float]:\n",
    "    \"\"\"Coifman--Lafon diffusion-map clustering.\n",
    "\n",
    "    The same base kernel K is used.  The alpha-normalized kernel is\n",
    "\n",
    "        K_alpha = D_p^{-alpha} K D_p^{-alpha},\n",
    "\n",
    "    where p_i is the kernel degree.  Alpha removes sampling density rather\n",
    "    than using it as a gate.\n",
    "    \"\"\"\n",
    "\n",
    "    p = np.asarray(K.sum(axis=1)).ravel() + EPS\n",
    "    P_alpha = diags(p ** (-alpha))\n",
    "    K_alpha = P_alpha @ K @ P_alpha\n",
    "\n",
    "    d_alpha = np.asarray(K_alpha.sum(axis=1)).ravel()\n",
    "    D_inv_sqrt = diags(1.0 / np.sqrt(d_alpha + EPS))\n",
    "\n",
    "    S = D_inv_sqrt @ K_alpha @ D_inv_sqrt\n",
    "    S = 0.5 * (S + S.T)\n",
    "\n",
    "    n_eigs = min(n_clusters + 1, K.shape[0] - 1)\n",
    "    vals, vecs = eigsh(S, k=n_eigs, which=\"LA\")\n",
    "\n",
    "    order = np.argsort(vals)[::-1]\n",
    "    vals = vals[order]\n",
    "    vecs = vecs[:, order]\n",
    "\n",
    "    laplacian_eigenvalues = 1.0 - vals\n",
    "\n",
    "    # Right eigenvectors of the row-stochastic diffusion operator.\n",
    "    psi = D_inv_sqrt @ vecs\n",
    "\n",
    "    # Drop the trivial coordinate and use the leading nontrivial diffusion coordinates.\n",
    "    coords = psi[:, 1:n_clusters] * (np.abs(vals[1:n_clusters]) ** diffusion_time)\n",
    "\n",
    "    labels = KMeans(\n",
    "        n_clusters=n_clusters,\n",
    "        n_init=20,\n",
    "        random_state=seed,\n",
    "    ).fit_predict(coords)\n",
    "\n",
    "    if len(laplacian_eigenvalues) > n_clusters:\n",
    "        eigengap = float(\n",
    "            laplacian_eigenvalues[n_clusters]\n",
    "            - laplacian_eigenvalues[n_clusters - 1]\n",
    "        )\n",
    "    else:\n",
    "        eigengap = np.nan\n",
    "\n",
    "    return labels, laplacian_eigenvalues, eigengap\n",
    "\n",
    "# ============================================================\n",
    "# Replicates and summaries\n",
    "# ============================================================\n",
    "\n",
    "def run_one_replicate(\n",
    "    seed: int,\n",
    "    setting: Dict[str, float],\n",
    "    config: ExperimentConfig,\n",
    ") -> Dict[str, np.ndarray]:\n",
    "    \"\"\"Run one replicate for all gamma and alpha values.\"\"\"\n",
    "\n",
    "    X, y = make_half_moons(\n",
    "        n_per_moon=config.n_per_moon,\n",
    "        noise=float(setting[\"noise\"]),\n",
    "        n_clutter=int(setting[\"n_clutter\"]),\n",
    "        seed=seed + config.random_seed_offset,\n",
    "    )\n",
    "\n",
    "    K, _ = gaussian_knn_kernel(X, k=config.k_nn)\n",
    "\n",
    "    gamma_ari = []\n",
    "    gamma_gap = []\n",
    "    for gamma in config.gamma_grid:\n",
    "        labels, _, gap = gamma_dirichlet_clustering(\n",
    "            K,\n",
    "            gamma=gamma,\n",
    "            n_clusters=config.n_clusters,\n",
    "            seed=seed,\n",
    "        )\n",
    "        gamma_ari.append(adjusted_rand_nonclutter(y, labels))\n",
    "        gamma_gap.append(gap)\n",
    "\n",
    "    dm_ari = []\n",
    "    dm_gap = []\n",
    "    for alpha in config.alpha_grid:\n",
    "        labels, _, gap = diffusion_map_clustering(\n",
    "            K,\n",
    "            alpha=alpha,\n",
    "            n_clusters=config.n_clusters,\n",
    "            seed=seed,\n",
    "        )\n",
    "        dm_ari.append(adjusted_rand_nonclutter(y, labels))\n",
    "        dm_gap.append(gap)\n",
    "\n",
    "    return {\n",
    "        \"gamma_ari\": np.asarray(gamma_ari),\n",
    "        \"gamma_gap\": np.asarray(gamma_gap),\n",
    "        \"dm_ari\": np.asarray(dm_ari),\n",
    "        \"dm_gap\": np.asarray(dm_gap),\n",
    "    }\n",
    "\n",
    "\n",
    "def summarize_grid(values: np.ndarray, grid: Tuple[float, ...]) -> pd.DataFrame:\n",
    "    \"\"\"Summarize a replicate-by-parameter array.\"\"\"\n",
    "\n",
    "    return pd.DataFrame(\n",
    "        {\n",
    "            \"parameter\": list(grid),\n",
    "            \"mean\": values.mean(axis=0),\n",
    "            \"sd\": values.std(axis=0),\n",
    "        }\n",
    "    )\n",
    "\n",
    "\n",
    "def run_experiment(config: ExperimentConfig) -> pd.DataFrame:\n",
    "    \"\"\"Run all settings and return a long-format summary table.\"\"\"\n",
    "\n",
    "    all_rows = []\n",
    "\n",
    "    for setting_name, setting in config.settings.items():\n",
    "        print(f\"Running setting: {setting_name}\")\n",
    "\n",
    "        outputs = Parallel(n_jobs=config.n_jobs)(\n",
    "            delayed(run_one_replicate)(seed, setting, config)\n",
    "            for seed in range(config.n_rep)\n",
    "        )\n",
    "\n",
    "        gamma_ari = np.vstack([out[\"gamma_ari\"] for out in outputs])\n",
    "        gamma_gap = np.vstack([out[\"gamma_gap\"] for out in outputs])\n",
    "        dm_ari = np.vstack([out[\"dm_ari\"] for out in outputs])\n",
    "        dm_gap = np.vstack([out[\"dm_gap\"] for out in outputs])\n",
    "\n",
    "        for j, gamma in enumerate(config.gamma_grid):\n",
    "            all_rows.append(\n",
    "                {\n",
    "                    \"setting\": setting_name,\n",
    "                    \"method\": \"Gamma-Dirichlet\",\n",
    "                    \"parameter_name\": \"gamma\",\n",
    "                    \"parameter\": gamma,\n",
    "                    \"mean_ari\": gamma_ari[:, j].mean(),\n",
    "                    \"sd_ari\": gamma_ari[:, j].std(),\n",
    "                    \"mean_eigengap\": gamma_gap[:, j].mean(),\n",
    "                    \"sd_eigengap\": gamma_gap[:, j].std(),\n",
    "                }\n",
    "            )\n",
    "\n",
    "        for j, alpha in enumerate(config.alpha_grid):\n",
    "            all_rows.append(\n",
    "                {\n",
    "                    \"setting\": setting_name,\n",
    "                    \"method\": \"Diffusion map\",\n",
    "                    \"parameter_name\": \"alpha\",\n",
    "                    \"parameter\": alpha,\n",
    "                    \"mean_ari\": dm_ari[:, j].mean(),\n",
    "                    \"sd_ari\": dm_ari[:, j].std(),\n",
    "                    \"mean_eigengap\": dm_gap[:, j].mean(),\n",
    "                    \"sd_eigengap\": dm_gap[:, j].std(),\n",
    "                }\n",
    "            )\n",
    "\n",
    "    summary = pd.DataFrame(all_rows)\n",
    "    return summary\n",
    "\n",
    "\n",
    "def format_mean_sd(mean: float, sd: float, digits: int = 3) -> str:\n",
    "    \"\"\"Format a mean and standard deviation as mean (sd).\"\"\"\n",
    "\n",
    "    return f\"{mean:.{digits}f} ({sd:.{digits}f})\"\n",
    "\n",
    "\n",
    "def wide_table(\n",
    "    summary: pd.DataFrame,\n",
    "    method: str,\n",
    "    parameter_name: str,\n",
    "    digits: int = 3,\n",
    ") -> pd.DataFrame:\n",
    "    \"\"\"Create a manuscript-style wide table.\"\"\"\n",
    "\n",
    "    sub = summary[summary[\"method\"] == method].copy()\n",
    "    sub[\"entry\"] = [\n",
    "        format_mean_sd(m, s, digits=digits)\n",
    "        for m, s in zip(sub[\"mean_ari\"], sub[\"sd_ari\"])\n",
    "    ]\n",
    "\n",
    "    table = sub.pivot(\n",
    "        index=\"setting\",\n",
    "        columns=\"parameter\",\n",
    "        values=\"entry\",\n",
    "    )\n",
    "\n",
    "    table.columns = [f\"{parameter_name}={v:g}\" for v in table.columns]\n",
    "    return table.reset_index()\n",
    "\n",
    "\n",
    "def save_summary_tables(summary: pd.DataFrame, config: ExperimentConfig) -> None:\n",
    "    \"\"\"Save CSV and LaTeX summaries.\"\"\"\n",
    "\n",
    "    os.makedirs(config.output_dir, exist_ok=True)\n",
    "\n",
    "    summary_path = os.path.join(config.output_dir, \"half_moons_summary_long.csv\")\n",
    "    summary.to_csv(summary_path, index=False)\n",
    "\n",
    "    gamma_table = wide_table(summary, \"Gamma-Dirichlet\", \"gamma\")\n",
    "    dm_table = wide_table(summary, \"Diffusion map\", \"alpha\")\n",
    "\n",
    "    gamma_csv = os.path.join(config.output_dir, \"half_moons_gamma_table.csv\")\n",
    "    dm_csv = os.path.join(config.output_dir, \"half_moons_diffusion_map_table.csv\")\n",
    "\n",
    "    gamma_tex = os.path.join(config.output_dir, \"half_moons_gamma_table.tex\")\n",
    "    dm_tex = os.path.join(config.output_dir, \"half_moons_diffusion_map_table.tex\")\n",
    "\n",
    "    gamma_table.to_csv(gamma_csv, index=False)\n",
    "    dm_table.to_csv(dm_csv, index=False)\n",
    "\n",
    "    gamma_table.to_latex(gamma_tex, index=False, escape=False)\n",
    "    dm_table.to_latex(dm_tex, index=False, escape=False)\n",
    "\n",
    "    print(f\"Saved {summary_path}\")\n",
    "    print(f\"Saved {gamma_csv}\")\n",
    "    print(f\"Saved {dm_csv}\")\n",
    "    print(f\"Saved {gamma_tex}\")\n",
    "    print(f\"Saved {dm_tex}\")"
   ]
