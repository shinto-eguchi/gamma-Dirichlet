    "# ============================================================\n",
    "# Figures\n",
    "# ============================================================\n",
    "\n",
    "def scatter_true_labels(\n",
    "    ax,\n",
    "    X: np.ndarray,\n",
    "    y: np.ndarray,\n",
    "    title: str,\n",
    "    clutter_color: str = \"magenta\",\n",
    ") -> None:\n",
    "    \"\"\"Plot true moon labels and mark clutter separately.\"\"\"\n",
    "\n",
    "    mask0 = y == 0\n",
    "    mask1 = y == 1\n",
    "    maskc = y < 0\n",
    "\n",
    "    ax.scatter(X[mask0, 0], X[mask0, 1], s=16, c=\"C0\", label=\"moon 0\")\n",
    "    ax.scatter(X[mask1, 0], X[mask1, 1], s=16, c=\"C1\", label=\"moon 1\")\n",
    "\n",
    "    if np.any(maskc):\n",
    "        ax.scatter(\n",
    "            X[maskc, 0],\n",
    "            X[maskc, 1],\n",
    "            s=20,\n",
    "            c=clutter_color,\n",
    "            marker=\"x\",\n",
    "            alpha=0.75,\n",
    "            label=\"clutter\",\n",
    "        )\n",
    "\n",
    "    ax.set_title(title)\n",
    "    ax.set_xticks([])\n",
    "    ax.set_yticks([])\n",
    "    ax.set_aspect(\"equal\", adjustable=\"box\")\n",
    "\n",
    "\n",
    "def scatter_cluster_labels(\n",
    "    ax,\n",
    "    X: np.ndarray,\n",
    "    y: np.ndarray,\n",
    "    labels: np.ndarray,\n",
    "    title: str,\n",
    "    clutter_color: str = \"magenta\",\n",
    ") -> None:\n",
    "    \"\"\"Plot predicted labels on clean points and show clutter separately.\"\"\"\n",
    "\n",
    "    clean = y >= 0\n",
    "    clutter = y < 0\n",
    "\n",
    "    ax.scatter(\n",
    "        X[clean, 0],\n",
    "        X[clean, 1],\n",
    "        c=labels[clean],\n",
    "        cmap=\"coolwarm\",\n",
    "        s=16,\n",
    "        linewidths=0,\n",
    "    )\n",
    "\n",
    "    if np.any(clutter):\n",
    "        ax.scatter(\n",
    "            X[clutter, 0],\n",
    "            X[clutter, 1],\n",
    "            c=clutter_color,\n",
    "            marker=\"x\",\n",
    "            s=22,\n",
    "            alpha=0.75,\n",
    "            linewidths=0.8,\n",
    "        )\n",
    "\n",
    "    ax.set_title(title)\n",
    "    ax.set_xticks([])\n",
    "    ax.set_yticks([])\n",
    "    ax.set_aspect(\"equal\", adjustable=\"box\")\n",
    "\n",
    "\n",
    "def plot_input_data(config: ExperimentConfig) -> None:\n",
    "    \"\"\"Save a clean-versus-clutter input data figure.\"\"\"\n",
    "\n",
    "    os.makedirs(config.output_dir, exist_ok=True)\n",
    "\n",
    "    X_clean, y_clean = make_half_moons(\n",
    "        n_per_moon=config.n_per_moon,\n",
    "        noise=0.00,\n",
    "        n_clutter=0,\n",
    "        seed=5,\n",
    "    )\n",
    "\n",
    "    X_clutter, y_clutter = make_half_moons(\n",
    "        n_per_moon=config.n_per_moon,\n",
    "        noise=0.08,\n",
    "        n_clutter=100,\n",
    "        seed=5,\n",
    "    )\n",
    "\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(8.4, 3.8))\n",
    "\n",
    "    scatter_true_labels(\n",
    "        axes[0],\n",
    "        X_clean,\n",
    "        y_clean,\n",
    "        title=\"(A) Clean half-moons\",\n",
    "    )\n",
    "\n",
    "    scatter_true_labels(\n",
    "        axes[1],\n",
    "        X_clutter,\n",
    "        y_clutter,\n",
    "        title=\"(B) Half-moons with scatter clutter\",\n",
    "    )\n",
    "\n",
    "    axes[1].legend(loc=\"upper right\", fontsize=8, frameon=True)\n",
    "\n",
    "    fig.tight_layout()\n",
    "\n",
    "    pdf_path = os.path.join(config.output_dir, \"half_moons_clean_vs_clutter.pdf\")\n",
    "    png_path = os.path.join(config.output_dir, \"half_moons_clean_vs_clutter.png\")\n",
    "\n",
    "    fig.savefig(pdf_path, bbox_inches=\"tight\")\n",
    "    fig.savefig(png_path, dpi=300, bbox_inches=\"tight\")\n",
    "    plt.show()\n",
    "\n",
    "    print(f\"Saved {pdf_path}\")\n",
    "    print(f\"Saved {png_path}\")\n",
    "\n",
    "\n",
    "def plot_method_panel(config: ExperimentConfig, seed: int = 1) -> None:\n",
    "    \"\"\"Save a 2x2 panel comparing density removal and density gating.\"\"\"\n",
    "\n",
    "    os.makedirs(config.output_dir, exist_ok=True)\n",
    "\n",
    "    X, y = make_half_moons(\n",
    "        n_per_moon=config.n_per_moon,\n",
    "        noise=0.08,\n",
    "        n_clutter=100,\n",
    "        seed=seed,\n",
    "    )\n",
    "\n",
    "    K, _ = gaussian_knn_kernel(X, k=config.k_nn)\n",
    "\n",
    "    methods = [\n",
    "        (\"Diffusion map, $\\\\alpha=0$\", diffusion_map_clustering(K, alpha=0.0, seed=seed)[0]),\n",
    "        (\"Diffusion map, $\\\\alpha=1$\", diffusion_map_clustering(K, alpha=1.0, seed=seed)[0]),\n",
    "        (\"Gamma-Dirichlet, $\\\\gamma=0$\", gamma_dirichlet_clustering(K, gamma=0.0, seed=seed)[0]),\n",
    "        (\"Gamma-Dirichlet, $\\\\gamma=1.5$\", gamma_dirichlet_clustering(K, gamma=1.5, seed=seed)[0]),\n",
    "    ]\n",
    "\n",
    "    fig, axes = plt.subplots(2, 2, figsize=(8.6, 7.4))\n",
    "\n",
    "    for ax, (title, labels) in zip(axes.ravel(), methods):\n",
    "        ari = adjusted_rand_nonclutter(y, labels)\n",
    "        scatter_cluster_labels(\n",
    "            ax,\n",
    "            X,\n",
    "            y,\n",
    "            labels,\n",
    "            title=f\"{title}\\nARI={ari:.3f}\",\n",
    "        )\n",
    "\n",
    "    fig.suptitle(\n",
    "        \"Half-moons with scatter clutter: density removal versus density gating\",\n",
    "        y=0.98,\n",
    "    )\n",
    "\n",
    "    fig.tight_layout(rect=[0, 0, 1, 0.95])\n",
    "\n",
    "    pdf_path = os.path.join(config.output_dir, \"half_moons_dm_vs_gamma_2x2.pdf\")\n",
    "    png_path = os.path.join(config.output_dir, \"half_moons_dm_vs_gamma_2x2.png\")\n",
    "\n",
    "    fig.savefig(pdf_path, bbox_inches=\"tight\")\n",
    "    fig.savefig(png_path, dpi=300, bbox_inches=\"tight\")\n",
    "    plt.show()\n",
    "\n",
    "    print(f\"Saved {pdf_path}\")\n",
    "    print(f\"Saved {png_path}\")\n",
    "\n",
    "\n",
    "def plot_sweeps(summary: pd.DataFrame, config: ExperimentConfig) -> None:\n",
    "    \"\"\"Save ARI curves over alpha and gamma.\"\"\"\n",
    "\n",
    "    os.makedirs(config.output_dir, exist_ok=True)\n",
    "\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(10.5, 4.2), sharey=True)\n",
    "\n",
    "    dm = summary[summary[\"method\"] == \"Diffusion map\"]\n",
    "    gd = summary[summary[\"method\"] == \"Gamma-Dirichlet\"]\n",
    "\n",
    "    for setting in config.settings:\n",
    "        sub = dm[dm[\"setting\"] == setting].sort_values(\"parameter\")\n",
    "        axes[0].errorbar(\n",
    "            sub[\"parameter\"],\n",
    "            sub[\"mean_ari\"],\n",
    "            yerr=sub[\"sd_ari\"],\n",
    "            marker=\"o\",\n",
    "            capsize=3,\n",
    "            label=setting,\n",
    "        )\n",
    "\n",
    "        sub = gd[gd[\"setting\"] == setting].sort_values(\"parameter\")\n",
    "        axes[1].errorbar(\n",
    "            sub[\"parameter\"],\n",
    "            sub[\"mean_ari\"],\n",
    "            yerr=sub[\"sd_ari\"],\n",
    "            marker=\"s\",\n",
    "            capsize=3,\n",
    "            label=setting,\n",
    "        )\n",
    "\n",
    "    axes[0].set_title(\"Diffusion map\")\n",
    "    axes[0].set_xlabel(r\"$\\alpha$  (density removed)\")\n",
    "    axes[0].set_ylabel(\"Adjusted Rand index\")\n",
    "\n",
    "    axes[1].set_title(\"Gamma-Dirichlet\")\n",
    "    axes[1].set_xlabel(r\"$\\gamma$  (density gated)\")\n",
    "\n",
    "    for ax in axes:\n",
    "        ax.set_ylim(-0.05, 1.05)\n",
    "        ax.grid(alpha=0.3)\n",
    "        ax.legend(fontsize=8, frameon=True)\n",
    "\n",
    "    fig.tight_layout()\n",
    "\n",
    "    pdf_path = os.path.join(config.output_dir, \"half_moons_dm_vs_gamma_sweeps.pdf\")\n",
    "    png_path = os.path.join(config.output_dir, \"half_moons_dm_vs_gamma_sweeps.png\")\n",
    "\n",
    "    fig.savefig(pdf_path, bbox_inches=\"tight\")\n",
    "    fig.savefig(png_path, dpi=300, bbox_inches=\"tight\")\n",
    "    plt.show()\n",
    "\n",
    "    print(f\"Saved {pdf_path}\")\n",
    "    print(f\"Saved {png_path}\")"
   ]
