    "# ============================================================\n",
    "# Data generation\n",
    "# ============================================================\n",
    "\n",
    "def make_half_moons(\n",
    "    n_per_moon: int = 150,\n",
    "    noise: float = 0.0,\n",
    "    n_clutter: int = 0,\n",
    "    seed: int = 0,\n",
    "    clutter_pad: float = 0.5,\n",
    ") -> Tuple[np.ndarray, np.ndarray]:\n",
    "    \"\"\"Generate two half-moons with optional uniform scatter clutter.\n",
    "\n",
    "    Parameters\n",
    "    ----------\n",
    "    n_per_moon:\n",
    "        Number of clean points in each moon.\n",
    "    noise:\n",
    "        Gaussian jitter used by sklearn.datasets.make_moons.\n",
    "    n_clutter:\n",
    "        Number of uniform background points.\n",
    "    seed:\n",
    "        Random seed.\n",
    "    clutter_pad:\n",
    "        Padding added to the bounding box before drawing clutter.\n",
    "\n",
    "    Returns\n",
    "    -------\n",
    "    X:\n",
    "        Array of shape (n, 2).\n",
    "    y:\n",
    "        Labels. Clean moon labels are 0 and 1; clutter points have label -1.\n",
    "    \"\"\"\n",
    "\n",
    "    rng = np.random.default_rng(seed)\n",
    "\n",
    "    X, y = make_moons(\n",
    "        n_samples=2 * n_per_moon,\n",
    "        noise=noise,\n",
    "        random_state=int(rng.integers(1 << 31)),\n",
    "    )\n",
    "\n",
    "    if n_clutter > 0:\n",
    "        lower = X.min(axis=0) - clutter_pad\n",
    "        upper = X.max(axis=0) + clutter_pad\n",
    "        clutter = rng.uniform(lower, upper, size=(int(n_clutter), 2))\n",
    "\n",
    "        X = np.vstack([X, clutter])\n",
    "        y = np.concatenate([y, np.full(int(n_clutter), -1, dtype=int)])\n",
    "\n",
    "    return X, y\n",
    "\n",
    "# ============================================================\n",
    "# Shared Gaussian kNN graph\n",
    "# ============================================================\n",
    "\n",
    "def gaussian_knn_kernel(\n",
    "    X: np.ndarray,\n",
    "    k: int = 15,\n",
    "    bandwidth: float | None = None,\n",
    ") -> Tuple[csr_matrix, float]:\n",
    "    \"\"\"Build a symmetric fixed-bandwidth Gaussian kNN kernel.\n",
    "\n",
    "    A single global bandwidth is used so that density variation remains in\n",
    "    the kernel degree.  This is important because both endpoint modulations\n",
    "    act on degree-based node weights.\n",
    "    \"\"\"\n",
    "\n",
    "    n = X.shape[0]\n",
    "    nn = NearestNeighbors(n_neighbors=k + 1).fit(X)\n",
    "    distances, indices = nn.kneighbors(X)\n",
    "\n",
    "    if bandwidth is None:\n",
    "        bandwidth = float(np.median(distances[:, 1:]))\n",
    "\n",
    "    rows = np.repeat(np.arange(n), k)\n",
    "    cols = indices[:, 1:].ravel()\n",
    "    weights = np.exp(-(distances[:, 1:].ravel() ** 2) / (2.0 * bandwidth ** 2))\n",
    "\n",
    "    K = csr_matrix((weights, (rows, cols)), shape=(n, n))\n",
    "    K = K.maximum(K.T)\n",
    "\n",
    "    return K, bandwidth\n",
    "\n",
    "# ============================================================\n",
    "# Spectral utilities\n",
    "# ============================================================\n",
    "\n",
    "def normalized_spectral_clustering(\n",
    "    affinity: csr_matrix,\n",
    "    n_clusters: int = 2,\n",
    "    seed: int = 0,\n",
    ") -> Tuple[np.ndarray, np.ndarray, float]:\n",
    "    \"\"\"Run normalized spectral clustering from a symmetric affinity matrix.\n",
    "\n",
    "    The eigenvectors are those of D^{-1/2} A D^{-1/2}.  The first\n",
    "    n_clusters eigenvectors are row-normalized before k-means, following the\n",
    "    Ng--Jordan--Weiss construction.\n",
    "    \"\"\"\n",
    "\n",
    "    degrees = np.asarray(affinity.sum(axis=1)).ravel()\n",
    "    D_inv_sqrt = diags(1.0 / np.sqrt(degrees + EPS))\n",
    "\n",
    "    S = D_inv_sqrt @ affinity @ D_inv_sqrt\n",
    "    S = 0.5 * (S + S.T)\n",
    "\n",
    "    n_eigs = min(n_clusters + 1, affinity.shape[0] - 1)\n",
    "    vals, vecs = eigsh(S, k=n_eigs, which=\"LA\")\n",
    "\n",
    "    order = np.argsort(vals)[::-1]\n",
    "    vals = vals[order]\n",
    "    vecs = vecs[:, order]\n",
    "\n",
    "    laplacian_eigenvalues = 1.0 - vals\n",
    "\n",
    "    U = vecs[:, :n_clusters]\n",
    "    U = U / (np.linalg.norm(U, axis=1, keepdims=True) + EPS)\n",
    "\n",
    "    labels = KMeans(\n",
    "        n_clusters=n_clusters,\n",
    "        n_init=20,\n",
    "        random_state=seed,\n",
    "    ).fit_predict(U)\n",
    "\n",
    "    if len(laplacian_eigenvalues) > n_clusters:\n",
    "        eigengap = float(\n",
    "            laplacian_eigenvalues[n_clusters]\n",
    "            - laplacian_eigenvalues[n_clusters - 1]\n",
    "        )\n",
    "    else:\n",
    "        eigengap = np.nan\n",
    "\n",
    "    return labels, laplacian_eigenvalues, eigengap\n",
    "\n",
    "\n",
    "def adjusted_rand_nonclutter(y_true: np.ndarray, labels: np.ndarray) -> float:\n",
    "    \"\"\"Compute ARI after removing uniform clutter points from the score.\"\"\"\n",
    "\n",
    "    mask = y_true >= 0\n",
    "    return float(adjusted_rand_score(y_true[mask], labels[mask]))"
   ]
