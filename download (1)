    "# ============================================================\n",
    "# Section 5.1: Half-moons with scatter noise\n",
    "# Gamma-Dirichlet clustering versus Coifman--Lafon diffusion maps\n",
    "#\n",
    "# This script is self-contained and Colab-friendly.\n",
    "# It generates the half-moon data, builds one shared Gaussian kNN graph,\n",
    "# compares the two endpoint modulations, and saves tables and figures.\n",
    "# ============================================================\n",
    "\n",
    "from __future__ import annotations\n",
    "\n",
    "import os\n",
    "from dataclasses import dataclass\n",
    "from typing import Dict, Tuple, List\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "from scipy.sparse import csr_matrix, diags\n",
    "from scipy.sparse.linalg import eigsh\n",
    "\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.datasets import make_moons\n",
    "from sklearn.metrics import adjusted_rand_score\n",
    "from sklearn.neighbors import NearestNeighbors\n",
    "\n",
    "from joblib import Parallel, delayed\n",
    "\n",
    "# ============================================================\n",
    "# Configuration\n",
    "# ============================================================\n",
    "\n",
    "@dataclass(frozen=True)\n",
    "class ExperimentConfig:\n",
    "    \"\"\"Configuration for the half-moon experiment.\"\"\"\n",
    "\n",
    "    n_per_moon: int = 150\n",
    "    n_rep: int = 12\n",
    "    n_jobs: int = 7\n",
    "    k_nn: int = 15\n",
    "    n_clusters: int = 2\n",
    "    random_seed_offset: int = 0\n",
    "    output_dir: str = \"gdc_figures\"\n",
    "\n",
    "    gamma_grid: Tuple[float, ...] = (0.0, 0.25, 0.5, 1.0, 1.5, 2.0, 2.5)\n",
    "    alpha_grid: Tuple[float, ...] = (0.0, 0.25, 0.5, 0.75, 1.0)\n",
    "\n",
    "    # Clutter is excluded from ARI evaluation and marked by label -1.\n",
    "    settings: Dict[str, Dict[str, float]] = None\n",
    "\n",
    "    def __post_init__(self):\n",
    "        if self.settings is None:\n",
    "            object.__setattr__(\n",
    "                self,\n",
    "                \"settings\",\n",
    "                {\n",
    "                    \"clean\": {\"noise\": 0.00, \"n_clutter\": 0},\n",
    "                    \"jitter\": {\"noise\": 0.12, \"n_clutter\": 0},\n",
    "                    \"clutter\": {\"noise\": 0.08, \"n_clutter\": 100},\n",
    "                },\n",
    "            )\n",
    "\n",
    "\n",
    "EPS = 1.0e-12"
   ]
