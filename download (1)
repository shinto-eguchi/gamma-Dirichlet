    "# ============================================================\n",
    "# Main routine\n",
    "# ============================================================\n",
    "\n",
    "def main() -> pd.DataFrame:\n",
    "    \"\"\"Run the full Section 5.1 experiment and save all outputs.\"\"\"\n",
    "\n",
    "    config = ExperimentConfig()\n",
    "    os.makedirs(config.output_dir, exist_ok=True)\n",
    "\n",
    "    # These figures are quick and useful for checking the data geometry.\n",
    "    plot_input_data(config)\n",
    "    plot_method_panel(config, seed=1)\n",
    "\n",
    "    # This part runs the replicate sweep used for the manuscript table.\n",
    "    summary = run_experiment(config)\n",
    "\n",
    "    print(\"\\nGamma-Dirichlet table:\")\n",
    "    print(wide_table(summary, \"Gamma-Dirichlet\", \"gamma\").to_string(index=False))\n",
    "\n",
    "    print(\"\\nDiffusion-map table:\")\n",
    "    print(wide_table(summary, \"Diffusion map\", \"alpha\").to_string(index=False))\n",
    "\n",
    "    save_summary_tables(summary, config)\n",
    "    plot_sweeps(summary, config)\n",
    "\n",
    "    return summary\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    summary = main()"
